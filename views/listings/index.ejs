<% layout('/layouts/boilerplate')%>

<div class="filter-container">
  <div id="filters">
    <a href="/listings<%= searchQuery ? '?search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= !selectedCategory ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-list"></i></div>
      <p>All</p>
    </a>
    <a href="/listings?category=Trending<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Trending' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Rooms' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Mountains' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castles<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Castles' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </a>
    <a href="/listings?category=Amazing Pools<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Amazing Pools' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </a>
    <a href="/listings?category=Camping<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Camping' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Farms' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="filter <%= selectedCategory === 'Arctic' ? 'active-filter' : '' %>" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
  </div>

  <div class="tax-toggle">
    <div class="form-check form-switch form-check-reverse">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display taxes</label>
    </div>
  </div>
</div>

<% if (allListings.length === 0) { %>
  <div class="container mt-5 text-center">
    <i class="fa-solid fa-magnifying-glass" style="font-size: 4rem; color: #ccc;"></i>
    <h3 class="mt-3">No listings found</h3>
    <p class="text-muted">Try adjusting your search or filters</p>
    <a href="/listings" class="btn btn-cls mt-3">View All Listings</a>
  </div>
<% } else { %>
  <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1">
    <%for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id  %>" class="listing-link">
        <div class="card col listing-card">

          <img src="<%= listing.image.url  %>" class="card-img-top" alt="listing_images" style="height:20rem">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <h5 class="card-title">
              <b>
                <%= listing.title %>
              </b>
            </h5>
            <p class="card-text">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>/night
              <i class="tax-info">&nbsp; +18% GST</i>
            </p>

            


          </div>
        </div>


      </a>

      <% } %>

  </div>
<% } %>


 